# Optional overrides (inventory_rag/.env is loaded first; this file wins on duplicate keys).
# Copy to `.env` for local values (`.env` is gitignored).

# RAG_SERVICE_URL=http://127.0.0.1:8787
# After DB writes, Node pings Python for debounced full reindex when RAG_INTERNAL_KEY is set (default on).
# Opt out: RAG_AUTO_REINDEX=false

# --- Email (new assignment requests + new public signups → admins; same SMTP) ---
# Optional product name in mail subject/body (default InvenTrack):
# APP_NAME=InvenTrack
# MAIL_BRAND=InvenTrack
# If set, only these addresses receive admin notify mail. If unset, every auth_users row with role=admin and a non-empty email receives mail.
# ADMIN_NOTIFY_EMAIL=you@example.com,other@example.com
# The submitter’s auth_users.email is never included in that admin broadcast (so they do not get the ops “new request” mail on their login).
# Gmail example (use App Password, not normal login password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=InvenTrack <you@gmail.com>
# Local/dev only if TLS errors to your SMTP: SMTP_TLS_REJECT_UNAUTHORIZED=0
# PUBLIC_APP_URL=http://localhost:4200
# Same secret signs login JWTs and short-lived “Approve from email” links (set in production).
# JWT_SECRET=
