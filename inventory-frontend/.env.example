# Copy to inventory-frontend/.env on Rocky Linux (gitignored). Used at build + PM2 runtime.
#
# Backend API URL — NO trailing slash. Use the same host/IP clients use to reach Node API.
# Examples:
#   BACKEND_ORIGIN=http://192.168.1.50:3000
#   BACKEND_ORIGIN=http://your-server.example.com:3000
BACKEND_ORIGIN=http://127.0.0.1:3000

# SSR Node server port (PM2). Open this port in firewalld if browsers hit the app directly.
PORT=4000

# Optional: same value as Inventory_backend PUBLIC_APP_URL (email links, redirects)
# PUBLIC_APP_URL=http://192.168.1.50:4000
