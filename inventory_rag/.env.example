# Copy to inventory_rag/.env — loaded from this folder even if you start uvicorn from the repo root.

INVENTORY_API_BASE=http://127.0.0.1:3000/api

GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=inventory
PINECONE_NAMESPACE=inventory-live

# Required for snapshot reindex (GET /api/rag-export/snapshot) and live chat grounding (GET /api/rag-export/summary).
RAG_INTERNAL_KEY=dev-inventtrack-rag-local-only

# RAG_SERVICE_URL=http://127.0.0.1:8787
# GEMINI_MODEL=gemini-2.5-flash
# If Flash hits 503 "high demand", optional second model after retries:
# GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# GOOGLE_API_RETRY_MAX_ATTEMPTS=6
# GOOGLE_API_RETRY_INITIAL_DELAY_SECONDS=2
# Debounce window for POST /internal/reindex-debounced (Node pings after writes when RAG is configured).
# RAG_REINDEX_DEBOUNCE_SECONDS=25
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_OUTPUT_DIMENSIONALITY=768
# Free-tier embed rate limits: smaller batches + longer pause if you still see 429.
# INDEX_EMBED_BATCH_SIZE=12
# INDEX_EMBED_SLEEP_SECONDS=5
