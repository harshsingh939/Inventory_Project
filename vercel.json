{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix inventory-frontend",
  "buildCommand": "npm run build --prefix inventory-frontend",
  "outputDirectory": "inventory-frontend/dist/inventory-frontend/browser",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
